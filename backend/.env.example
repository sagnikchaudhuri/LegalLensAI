# Optional. Leave empty to use deterministic local rule-based analysis.
GEMINI_API_KEY=

# Gemini model used when GEMINI_API_KEY is configured.
GEMINI_MODEL=gemini-2.0-flash

# Frontend origin allowed by CORS.
# Use http://localhost:5173 locally and your Vercel origin on Render.
FRONTEND_URL=https://legallensai.vercel.app
CORS_ALLOWED_ORIGINS=https://legallensai.vercel.app
CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
API_DEBUG=false

# Upload and request security limits.
MAX_UPLOAD_SIZE_BYTES=15728640
DOCUMENT_AUTO_EXPIRE_HOURS=24
REDACT_PII_FOR_LLM=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_SIZE_BYTES=20971520

# Optional persistent storage paths. Useful when Render mounts a disk outside the repo.
# UPLOADS_DIR=/var/data/uploads
# DATA_DIR=/var/data/data
# AUDIT_LOG_PATH=/var/data/audit.log

# Replace this before sharing a deployed instance.
AUDIT_HASH_SALT=replace-with-a-random-local-secret

# Optional Firebase Authentication enforcement for API routes.
# Set AUTH_REQUIRED=true in deployed environments after Firebase is configured.
AUTH_REQUIRED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Embedding model runtime. Preload this model on Render before first traffic.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_WARMUP_ON_START=true
